[Unit]
Description=IC Report (Hampton Tower 物业管理系统)
After=network.target

[Service]
Type=simple
User=icreport
Group=icreport
WorkingDirectory=/opt/ic_report
# 单 worker + 多线程：数据是扁平 JSON 文件读改写，多进程会并发写坏数据
# timeout 拉长到 120s 以容纳大图片（base64）上传
ExecStart=/opt/ic_report/.venv/bin/gunicorn \
    --workers 1 \
    --threads 8 \
    --timeout 120 \
    --bind 0.0.0.0:8000 \
    app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
