[Unit]
Description=IC Report GitHub Webhook 自动部署接收器
After=network.target

[Service]
Type=simple
User=icreport
Group=icreport
WorkingDirectory=/opt/ic_report/deploy
# WEBHOOK_SECRET 在此文件中定义（仅 root/icreport 可读）
EnvironmentFile=/etc/ic_report_webhook.env
ExecStart=/opt/ic_report/.venv/bin/gunicorn --workers 1 --bind 0.0.0.0:9000 webhook:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
